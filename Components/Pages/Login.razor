@page "/login"
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Login — ParkSolutions</PageTitle>

<div class="login-page">

    <div class="login-left">
        <div class="brand">
            <div class="brand-icon">
                <span class="bi bi-p-circle-fill"></span>
            </div>
            <div>
                <div class="brand-name">ParkSolutions</div>
                <div class="brand-tagline">Sistema de Controle</div>
            </div>
        </div>

        <div class="hero-text">
            <h1>Gerencie seu<br />estacionamento<br /><span class="highlight">com inteligência.</span></h1>
            <p>Controle entradas, saídas, vagas e faturamento em tempo real — tudo em um só lugar.</p>
        </div>

        <div class="stats-row">
            <div class="stat">
                <div class="stat-val">99%</div>
                <div class="stat-label">Uptime</div>
            </div>
            <div class="stat-div"></div>
            <div class="stat">
                <div class="stat-val">+500</div>
                <div class="stat-label">Veículos/dia</div>
            </div>
            <div class="stat-div"></div>
            <div class="stat">
                <div class="stat-val">24h</div>
                <div class="stat-label">Monitoramento</div>
            </div>
        </div>
    </div>

    <div class="login-right">
        <div class="login-card">

            <div class="login-card-header">
                <div class="login-card-title">Bem-vindo de volta</div>
                <div class="login-card-sub">Entre com suas credenciais para continuar</div>
            </div>

            <!-- Botão Google -->
            <a href="/auth/google-login" class="btn-google">
                <svg width="18" height="18" viewBox="0 0 48 48" style="flex-shrink:0;">
                    <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                    <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                    <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                    <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                </svg>
                Continuar com Google
            </a>

            <div class="divider">
                <span class="div-line"></span>
                <span class="divider-text">ou entre com e-mail</span>
                <span class="div-line"></span>
            </div>

            @if (!string.IsNullOrEmpty(erro))
            {
                <div class="alert-erro">
                    <span class="bi bi-exclamation-triangle-fill me-2"></span>@erro
                </div>
            }

            <div class="lform">

                <div class="lform-group">
                    <label>E-mail</label>
                    <div class="linput-wrap @(emailFocus ? "focused" : "")">
                        <span class="bi bi-envelope-fill linput-icon"></span>
                        <input type="email"
                               placeholder="seu@email.com"
                               @bind="email"
                               @onfocus="() => emailFocus = true"
                               @onblur="() => emailFocus = false" />
                    </div>
                </div>

                <div class="lform-group">
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                        <label>Senha</label>
                        <a href="#" class="forgot-link">Esqueceu a senha?</a>
                    </div>
                    <div class="linput-wrap @(senhaFocus ? "focused" : "")">
                        <span class="bi bi-lock-fill linput-icon"></span>
                        <input type="@(mostrarSenha ? "text" : "password")"
                               placeholder="••••••••"
                               @bind="senha"
                               @onfocus="() => senhaFocus = true"
                               @onblur="() => senhaFocus = false" />
                        <button class="toggle-pass" @onclick="() => mostrarSenha = !mostrarSenha" type="button">
                            <span class="bi @(mostrarSenha ? "bi-eye-slash-fill" : "bi-eye-fill")"></span>
                        </button>
                    </div>
                </div>

                <div class="remember-row">
                    <label class="remember-label">
                        <input type="checkbox" @bind="lembrar" />
                        <span>Lembrar de mim</span>
                    </label>
                </div>

                <button class="btn-login @(carregando ? "loading" : "")" @onclick="Entrar" disabled="@carregando">
                    @if (carregando)
                    {
                        <span class="spinner"></span>
                        <span>Entrando...</span>
                    }
                    else
                    {
                        <span class="bi bi-box-arrow-in-right me-2"></span>
                        <span>Entrar</span>
                    }
                </button>

            </div>

            <div class="login-footer">
                Não tem uma conta? <a href="#" class="link-blue">Solicite acesso</a>
            </div>

        </div>
    </div>

</div>

@code {
    private string email = "";
    private string senha = "";
    private string erro  = "";
    private bool lembrar      = false;
    private bool mostrarSenha = false;
    private bool carregando   = false;
    private bool emailFocus   = false;
    private bool senhaFocus   = false;

    private async Task Entrar()
    {
        erro = "";

        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(senha))
        {
            erro = "Preencha e-mail e senha para continuar.";
            return;
        }

        carregando = true;
        await Task.Delay(1500);

        if (email == "admin@park.com" && senha == "123456")
        {
            // NavigationManager.NavigateTo("/");
        }
        else
        {
            erro = "E-mail ou senha incorretos.";
        }

        carregando = false;
    }
}

<style>
    .login-page {
        display: flex;
        min-height: 100vh;
        background: #12122a;
        font-family: 'Segoe UI', sans-serif;
    }

    .login-left {
        flex: 1;
        background: linear-gradient(145deg, #1a1a40 0%, #0f1628 100%);
        border-right: 1px solid #2a2a4a;
        padding: 48px 52px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .brand { display:flex; align-items:center; gap:14px; }

    .brand-icon {
        width:48px; height:48px; background:#2563eb;
        border-radius:12px; display:flex; align-items:center;
        justify-content:center; font-size:26px; color:#fff;
    }

    .brand-name   { color:#fff; font-size:18px; font-weight:700; }
    .brand-tagline{ color:#8888aa; font-size:12px; }

    .hero-text h1 {
        color:#fff; font-size:38px; font-weight:700;
        line-height:1.2; margin:0 0 18px;
    }

    .highlight { color:#2563eb; }

    .hero-text p {
        color:#8888aa; font-size:15px;
        line-height:1.7; max-width:380px; margin:0;
    }

    .stats-row { display:flex; align-items:center; gap:28px; }
    .stat-val  { color:#fff; font-size:22px; font-weight:700; }
    .stat-label{ color:#8888aa; font-size:12px; margin-top:2px; }
    .stat-div  { width:1px; height:36px; background:#2a2a4a; }

    .login-right {
        width:480px; display:flex;
        align-items:center; justify-content:center;
        padding:40px 36px;
    }

    .login-card { width:100%; display:flex; flex-direction:column; gap:20px; }

    .login-card-header { text-align:center; }
    .login-card-title  { color:#fff; font-size:22px; font-weight:700; margin-bottom:6px; }
    .login-card-sub    { color:#8888aa; font-size:14px; }

    /* Google */
    .btn-google {
        display:flex; align-items:center; justify-content:center; gap:12px;
        background:#fff; color:#1a1a2e;
        border:none; border-radius:10px;
        padding:13px; font-size:14px; font-weight:600;
        cursor:pointer; text-decoration:none;
        transition:background 0.2s, transform 0.1s;
        width:100%;
    }

    .btn-google:hover  { background:#f1f5f9; }
    .btn-google:active { transform:scale(0.98); }

    /* Divider */
    .divider {
        display:flex; align-items:center; gap:12px;
    }

    .div-line {
        flex:1; height:1px; background:#2a2a4a; display:block;
    }

    .divider-text {
        color:#8888aa; font-size:12px; white-space:nowrap;
    }

    /* Alert */
    .alert-erro {
        background:#2e1515; border:1px solid #ef4444;
        color:#f87171; border-radius:10px;
        padding:12px 16px; font-size:13px;
    }

    /* Form */
    .lform { display:flex; flex-direction:column; gap:16px; }

    .lform-group { display:flex; flex-direction:column; gap:7px; }

    .lform-group label {
        color:#8888aa; font-size:12px; font-weight:600;
        text-transform:uppercase; letter-spacing:0.5px;
    }

    .linput-wrap {
        display:flex; align-items:center; gap:10px;
        background:#1e1e3a; border:1px solid #2a2a4a;
        border-radius:10px; padding:11px 14px;
        transition:border-color 0.2s, box-shadow 0.2s;
    }

    .linput-wrap.focused {
        border-color:#2563eb;
        box-shadow:0 0 0 3px rgba(37,99,235,0.15);
    }

    .linput-icon { color:#8888aa; font-size:15px; flex-shrink:0; }

    .linput-wrap input {
        background:transparent; border:none; outline:none;
        color:#fff; font-size:14px; flex:1;
    }

    .linput-wrap input::placeholder { color:#3a3a5a; }

    .toggle-pass {
        background:transparent; border:none;
        color:#8888aa; cursor:pointer; font-size:15px;
        padding:0; transition:color 0.2s; flex-shrink:0;
    }

    .toggle-pass:hover { color:#fff; }

    .forgot-link { color:#2563eb; font-size:12px; text-decoration:none; }
    .forgot-link:hover { text-decoration:underline; }

    .remember-row { margin-top:-4px; }

    .remember-label {
        display:flex; align-items:center; gap:8px;
        color:#8888aa; font-size:13px; cursor:pointer;
    }

    .remember-label input[type="checkbox"] {
        accent-color:#2563eb; width:15px; height:15px;
    }

    .btn-login {
        background:#2563eb; border:none; color:#fff;
        padding:14px; border-radius:10px;
        font-size:15px; font-weight:700;
        cursor:pointer; transition:background 0.2s, transform 0.1s;
        width:100%;
        display:flex; align-items:center; justify-content:center; gap:6px;
        margin-top:4px;
    }

    .btn-login:hover:not(:disabled)  { background:#1d4fd8; }
    .btn-login:active:not(:disabled) { transform:scale(0.98); }
    .btn-login:disabled { opacity:0.7; cursor:not-allowed; }

    .spinner {
        width:16px; height:16px;
        border:2px solid rgba(255,255,255,0.3);
        border-top-color:#fff; border-radius:50%;
        animation:spin 0.7s linear infinite;
        display:inline-block;
    }

    @@keyframes spin { to { transform:rotate(360deg); } }

    .login-footer { text-align:center; color:#8888aa; font-size:13px; }

    .link-blue { color:#2563eb; text-decoration:none; font-weight:600; }
    .link-blue:hover { text-decoration:underline; }

    @@media (max-width:820px) {
        .login-left  { display:none; }
        .login-right { width:100%; }
    }
</style>
